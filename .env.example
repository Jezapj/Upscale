# Server-side only — not bundled into the client.
# Copy to .env for local dev (Vite serves /api/config from these at dev time).

# Google Sign-In (OAuth 2.0 Web client ID)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Firebase (cross-device sync for Google accounts)
# https://console.firebase.google.com — enable Auth (Google) + Firestore
# Deploy firestore.rules from this repo.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
