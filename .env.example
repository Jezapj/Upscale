# Optional Google Sign-In.
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Add your dev origin (e.g. http://localhost:5173) to "Authorized JavaScript origins".
# Then copy the Client ID below. If left blank, the app runs in Guest mode.
VITE_GOOGLE_CLIENT_ID=

# Firebase (cross-device sync for Google accounts)
# https://console.firebase.google.com — enable Auth (Google) + Firestore
# Deploy firestore.rules from this repo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
