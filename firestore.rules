rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Google sign-in via Firebase Auth: token.sub matches the document id.
    match /userdata/{googleSub} {
      allow read, write: if request.auth != null && request.auth.token.sub == googleSub;
    }

    // Global daily arcade boards — one create-once entry per user per day/game.
    match /dailyBoards/{boardId}/entries/{uid} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.token.sub == uid
        && request.resource.data.keys().hasAll(['uid', 'score', 'displayName', 'playedAt', 'gameId', 'day'])
        && request.resource.data.uid == uid
        && request.resource.data.score is number
        && request.resource.data.playedAt is string
        && request.resource.data.gameId is string
        && request.resource.data.day is string
        && (request.resource.data.displayName == null || request.resource.data.displayName is string);

      allow update, delete: if false;
    }
  }
}
